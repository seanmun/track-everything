{
  "name": "lifelog",
  "version": "2.0.0",
  "description": "Single-user personal health data lake — Telegram ingest, Oura pull, LLM/vision analysis over SQLite.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.44.2",
    "grammy": "^1.36.0",
    "hono": "^4.8.0",
    "node-cron": "^3.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.15.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
